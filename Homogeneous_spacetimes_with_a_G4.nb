Cell[TextData[{
 "In this case, we will obtain the connection tensor ",
 StyleBox["H",
  FontSlant->"Italic"],
 " by obtaining the Weyl principal frame:"
}], "Text",
 CellChangeTimes->{{3.9314044012908096`*^9, 3.9314045043194904`*^9}, {
   3.9314045343308105`*^9, 3.9314045450184116`*^9}, {3.9314064147514057`*^9, 
