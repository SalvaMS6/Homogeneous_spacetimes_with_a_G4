Cell[BoxData[{
 RowBox[{
  RowBox[{"CD", "=", 
   RowBox[{"CovDOfMetric", "[", "metric", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"R", "=", 
   RowBox[{"Ricci", "[", "CD", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"r", "=", 
   RowBox[{
    RowBox[{"R", "[", 
     RowBox[{"a", ",", 
      RowBox[{"-", "a"}]}], "]"}], "//", "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"S", "=", 
   RowBox[{"R", "-", 
    RowBox[{
     FractionBox["1", "4"], "r", " ", "metric"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"S2", "=", 
   RowBox[{"HeadOfTensor", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"S", "[", 
       RowBox[{
        RowBox[{"-", "a"}], ",", "i"}], "]"}], 
      RowBox[{"S", "[", 
       RowBox[{
        RowBox[{"-", "i"}], ",", 
        RowBox[{"-", "b"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "a"}], ",", 
       RowBox[{"-", "b"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"trS2", "=", 
   RowBox[{"S2", "[", 
    RowBox[{"a", ",", 
     RowBox[{"-", "a"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"S3", "=", 
   RowBox[{"HeadOfTensor", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"S2", "[", 
       RowBox[{
        RowBox[{"-", "a"}], ",", "i"}], "]"}], 
      RowBox[{"S", "[", 
       RowBox[{
        RowBox[{"-", "i"}], ",", 
        RowBox[{"-", "b"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "a"}], ",", 
       RowBox[{"-", "b"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"trS3", "=", 
   RowBox[{"S3", "[", 
    RowBox[{"a", ",", 
     RowBox[{"-", "a"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"q", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "2"}], 
     FractionBox["trS3", "trS2"]}], "//", "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Q", "=", 
   RowBox[{"S", "-", 
    RowBox[{
     FractionBox["1", "4"], "q", " ", "metric"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"P", "=", 
   RowBox[{"Q", "/", "q"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalSigma]", "=", 
   RowBox[{
    RowBox[{"HeadOfTensor", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        FractionBox["1", "2"]}], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"CD", "[", 
           RowBox[{"-", "a"}], "]"}], "[", 
          RowBox[{"P", "[", 
           RowBox[{
            RowBox[{"-", "b"}], ",", 
            RowBox[{"-", "m"}]}], "]"}], "]"}], "+", 
         RowBox[{
          RowBox[{"CD", "[", 
           RowBox[{"-", "b"}], "]"}], "[", 
          RowBox[{"P", "[", 
           RowBox[{
            RowBox[{"-", "a"}], ",", 
            RowBox[{"-", "m"}]}], "]"}], "]"}]}], ")"}], 
       RowBox[{"P", "[", 
        RowBox[{"m", ",", 
         RowBox[{"-", "l"}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "a"}], ",", 
        RowBox[{"-", "b"}], ",", 
        RowBox[{"-", "l"}]}], "}"}]}], "]"}], "//", "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[ScriptX]", "=", 
   RowBox[{
    RowBox[{"HeadOfTensor", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        RowBox[{"\[CapitalSigma]", "[", 
         RowBox[{
          RowBox[{"-", "b"}], ",", 
          RowBox[{"-", "l"}], ",", 
          RowBox[{"-", "m"}]}], "]"}]}], 
       RowBox[{"\[CapitalSigma]", "[", 
        RowBox[{
         RowBox[{"-", "c"}], ",", "l", ",", "m"}], "]"}], 
       RowBox[{"\[CapitalSigma]", "[", 
        RowBox[{"b", ",", "c", ",", "a"}], "]"}]}], ",", 
      RowBox[{"{", "a", "}"}]}], "]"}], "//", "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Sigma]2", "=", 
   RowBox[{
    RowBox[{"HeadOfTensor", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        RowBox[{"\[CapitalSigma]", "[", 
         RowBox[{
          RowBox[{"-", "a"}], ",", 
          RowBox[{"-", "l"}], ",", 
          RowBox[{"-", "m"}]}], "]"}]}], 
       RowBox[{"\[CapitalSigma]", "[", 
        RowBox[{
         RowBox[{"-", "b"}], ",", "l", ",", "m"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "a"}], ",", 
        RowBox[{"-", "b"}]}], "}"}]}], "]"}], "//", "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Alpha]\[Sigma]", "=", 
   RowBox[{
    RowBox[{"\[Sigma]2", "[", 
     RowBox[{"a", ",", 
      RowBox[{"-", "a"}]}], "]"}], "//", "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Delta]\[Sigma]", "=", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[Alpha]\[Sigma]", "3"], "-", 
     RowBox[{"6", 
      RowBox[{"\[ScriptX]", "[", "a", "]"}], 
      RowBox[{"\[ScriptX]", "[", 
       RowBox[{"-", "a"}], "]"}]}]}], "//", "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"KK", "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "\[Delta]\[Sigma]"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"3", "\[Alpha]\[Sigma]", "  ", "\[Sigma]2"}], "+", 
       RowBox[{"6", 
        RowBox[{"\[CapitalSigma]", "[", 
         RowBox[{
          RowBox[{"-", "a"}], ",", 
          RowBox[{"-", "b"}], ",", 
          RowBox[{"-", "c"}]}], "]"}], 
        RowBox[{"\[ScriptX]", "[", "c", "]"}]}], "+", 
       RowBox[{
        FractionBox["1", "2"], 
        SuperscriptBox["\[Alpha]\[Sigma]", "2"], 
        RowBox[{"(", 
         RowBox[{"metric", "+", "P"}], ")"}]}]}], ")"}]}], "//", 
    "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"J", "=", 
   RowBox[{
    RowBox[{"HeadOfTensor", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"CD", "[", 
         RowBox[{"-", "a"}], "]"}], "[", 
        RowBox[{"\[CapitalSigma]", "[", 
         RowBox[{"b", ",", 
          RowBox[{"-", "c"}], ",", 
          RowBox[{"-", "d"}]}], "]"}], "]"}], 
       RowBox[{"\[CapitalSigma]", "[", 
        RowBox[{"c", ",", "e", ",", 
         RowBox[{"-", "f"}]}], "]"}], 
       RowBox[{"P", "[", 
        RowBox[{"d", ",", "f"}], "]"}], 
       RowBox[{
        RowBox[{"epsilon", "[", "metric", "]"}], "[", 
        RowBox[{
         RowBox[{"-", "b"}], ",", 
         RowBox[{"-", "e"}], ",", 
         RowBox[{"-", "g"}], ",", 
         RowBox[{"-", "h"}]}], "]"}], 
       RowBox[{"KK", "[", 
        RowBox[{"g", ",", "i"}], "]"}], 
       RowBox[{
        RowBox[{"epsilon", "[", "metric", "]"}], "[", 
        RowBox[{
         RowBox[{"-", "i"}], ",", 
         RowBox[{"-", "j"}], ",", 
         RowBox[{"-", "k"}], ",", 
         RowBox[{"-", "l"}]}], "]"}], 
       RowBox[{"P", "[", 
        RowBox[{"h", ",", "l"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "a"}], ",", 
        RowBox[{"-", "j"}], ",", 
        RowBox[{"-", "k"}]}], "}"}]}], "]"}], "//", "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[ScriptCapitalI]", "=", 
   RowBox[{
    RowBox[{"HeadOfTensor", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         RowBox[{
          RowBox[{"CD", "[", 
           RowBox[{"-", "a"}], "]"}], "[", 
          RowBox[{"P", "[", 
           RowBox[{"i", ",", 
            RowBox[{"-", "b"}]}], "]"}], "]"}]}], 
        RowBox[{"P", "[", 
         RowBox[{
          RowBox[{"-", "c"}], ",", 
          RowBox[{"-", "i"}]}], "]"}]}], "+", 
       RowBox[{
        RowBox[{
         RowBox[{"CD", "[", 
          RowBox[{"-", "a"}], "]"}], "[", 
         RowBox[{"P", "[", 
          RowBox[{"i", ",", 
