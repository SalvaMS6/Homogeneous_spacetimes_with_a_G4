Cell["Then, we define the manifold and chart", "Text",
 CellChangeTimes->{{3.9882480643516903`*^9, 
  3.9882480734636345`*^9}},ExpressionUUID->"e39a29fe-ba23-1440-9679-\
9ffec42d4f71"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DefManifold", "[", 
   RowBox[{"M", ",", "4", ",", 
    RowBox[{"IndexRange", "[", 
     RowBox[{"a", ",", "n"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DefChart", "[", 
   RowBox[{"chart", ",", "M", ",", 
    RowBox[{"{", 
     RowBox[{"0", ",", "1", ",", "2", ",", "3"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"t", "[", "]"}], ",", 
      RowBox[{"x", "[", "]"}], ",", 
      RowBox[{"y", "[", "]"}], ",", 
      RowBox[{"z", "[", "]"}]}], "}"}]}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.915246209030916*^9, 3.9152462759776225`*^9}, 
   3.915246307076542*^9, {3.930892557296896*^9, 3.93089257032023*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"1ff34681-1ef4-2447-91c1-b6ab167b7513"],

Cell["and some constants that we will need:", "Text",
 CellChangeTimes->{{3.9882480030545692`*^9, 3.9882480033267174`*^9}, {
  3.988248079733488*^9, 
  3.9882481060455284`*^9}},ExpressionUUID->"84650dc9-8779-c44c-9485-\
d3c742e35e7b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DefConstantSymbol", "[", "s", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DefConstantSymbol", "[", 
   RowBox[{"\[ScriptA]", ",", 
    RowBox[{"PrintAs", "->", "\"\<a\>\""}]}], "]"}], ";"}]}], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"6875b515-c0bd-ee45-a88b-57d43160815a"],

Cell[CellGroupData[{

Cell["Farnsworth-Kerr", "Section",
 CellChangeTimes->{{3.9774540809972878`*^9, 
  3.977454091360979*^9}},ExpressionUUID->"747a624e-812b-8e4a-aefe-\
d2888801eaf2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Omega]1", "=", 
   RowBox[{"dx", "-", 
    RowBox[{
     RowBox[{"Sinh", "[", 
      RowBox[{"y", "[", "]"}], "]"}], "dz"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Omega]2", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"x", "[", "]"}], "]"}], "dy"}], "-", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"x", "[", "]"}], "]"}], 
     RowBox[{"Cosh", "[", 
      RowBox[{"y", "[", "]"}], "]"}], "dz"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Omega]3", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"x", "[", "]"}], "]"}], "dy"}], "+", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"x", "[", "]"}], "]"}], 
     RowBox[{"Cosh", "[", 
      RowBox[{"y", "[", "]"}], "]"}], "dz"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.977454743535841*^9, 3.9774547476806736`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"d16b0599-d8d8-cd4b-8183-d4fd7256446c"],

Cell[CellGroupData[{

Cell["Class II", "Subsubsection",
 CellChangeTimes->{{3.9774617728964157`*^9, 
  3.9774617742680664`*^9}},ExpressionUUID->"04e0ed1b-1cd4-114f-a6e8-\
e23796a585a1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"UnsetCMetric", "[", "metric", "]"}], ";"}]], "Input",
 CellLabel->"In[25]:=",ExpressionUUID->"3517f35e-f002-d04e-b656-39842871adc6"],

Cell["We start by defining the metric (40) and some constraints", "Text",
 CellChangeTimes->{{3.9882479864188576`*^9, 3.9882479884053726`*^9}, {
  3.988248116954962*^9, 3.9882481412554455`*^9}, {3.9882489030024376`*^9, 
  3.988248904288727*^9}, {3.9904443956792507`*^9, 
  3.9904443957587776`*^9}},ExpressionUUID->"35db1b2b-1f18-564c-a5cb-\
25b75b0b0ec2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$Assumptions", "=", 
   RowBox[{
    RowBox[{"s", "\[Element]", "Reals"}], "&&", 
    RowBox[{"\[ScriptA]", "\[Element]", "Reals"}], "&&", 
    RowBox[{
     RowBox[{"1", "-", 
      RowBox[{"4", 
       SuperscriptBox["s", "2"]}]}], "<", "0"}], "&&", 
    RowBox[{
     RowBox[{"2", "-", 
      RowBox[{"4", 
       SuperscriptBox["s", "2"]}]}], ">=", "0"}], "&&", 
    RowBox[{
     RowBox[{"y", "[", "]"}], "\[Element]", "Reals"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9774621672901497`*^9, 3.9774621887394047`*^9}, {
  3.9774623676420937`*^9, 3.9774623797981796`*^9}, {3.977994634223921*^9, 
  3.9779946404986935`*^9}, {3.9793524591830864`*^9, 3.9793524650374737`*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"48fe5fb3-b32d-184b-aaa6-0c991fa895e0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"linelement", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "s"}], ")"}], 
     SuperscriptBox["\[Omega]3", "2"]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", "s"}], ")"}], 
     SuperscriptBox["\[Omega]2", "2"]}], "-", 
    RowBox[{"2", 
     SuperscriptBox["\[Omega]1", "2"]}], "+", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"dt", "+", 
       RowBox[{
        SqrtBox[
         RowBox[{"1", "-", 
          RowBox[{"2", 
           SuperscriptBox["s", "2"]}]}]], "\[Omega]1"}]}], ")"}], "2"]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"linelement", "=", 
   RowBox[{"Collect", "[", 
    RowBox[{"linelement", ",", 
     RowBox[{"{", 
      RowBox[{
       SuperscriptBox["dt", "2"], ",", 
       SuperscriptBox["dx", "2"], ",", 
       SuperscriptBox["dy", "2"], ",", 
       SuperscriptBox["dz", "2"], ",", 
       RowBox[{"dx", " ", "dz"}], ",", 
       RowBox[{"dy", " ", "dz"}]}], "}"}], ",", "Simplify"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"metricMatrix", "=", "\[IndentingNewLine]", 
   RowBox[{
    SuperscriptBox["\[ScriptA]", "2"], 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Coefficient", "[", 
         RowBox[{"linelement", ",", 
          SuperscriptBox["dt", "2"]}], "]"}], ",", 
        RowBox[{
         RowBox[{"Coefficient", "[", 
          RowBox[{"linelement", ",", 
           RowBox[{"dt", " ", "dx"}]}], "]"}], "/", "2"}], ",", 
        RowBox[{
         RowBox[{"Coefficient", "[", 
          RowBox[{"linelement", ",", 
           RowBox[{"dt", " ", "dy"}]}], "]"}], "/", "2"}], ",", 
        RowBox[{
         RowBox[{"Coefficient", "[", 
          RowBox[{"linelement", ",", 
           RowBox[{"dt", " ", "dz"}]}], "]"}], "/", "2"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Coefficient", "[", 
          RowBox[{"linelement", ",", 
           RowBox[{"dx", " ", "dt"}]}], "]"}], "/", "2"}], ",", 
        RowBox[{"Coefficient", "[", 
         RowBox[{"linelement", ",", 
          SuperscriptBox["dx", "2"]}], "]"}], ",", 
        RowBox[{
         RowBox[{"Coefficient", "[", 
          RowBox[{"linelement", ",", 
           RowBox[{"dx", " ", "dy"}]}], "]"}], "/", "2"}], ",", 
        RowBox[{
         RowBox[{"Coefficient", "[", 
          RowBox[{"linelement", ",", 
           RowBox[{"dx", " ", "dz"}]}], "]"}], "/", "2"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Coefficient", "[", 
          RowBox[{"linelement", ",", 
           RowBox[{"dy", " ", "dt"}]}], "]"}], "/", "2"}], ",", 
        RowBox[{
         RowBox[{"Coefficient", "[", 
          RowBox[{"linelement", ",", 
           RowBox[{"dy", " ", "dx"}]}], "]"}], "/", "2"}], ",", 
        RowBox[{"Coefficient", "[", 
         RowBox[{"linelement", ",", 
          SuperscriptBox["dy", "2"]}], "]"}], ",", 
        RowBox[{
         RowBox[{"Coefficient", "[", 
          RowBox[{"linelement", ",", 
           RowBox[{"dy", " ", "dz"}]}], "]"}], "/", "2"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Coefficient", "[", 
          RowBox[{"linelement", ",", 
           RowBox[{"dz", " ", "dt"}]}], "]"}], "/", "2"}], ",", 
        RowBox[{
         RowBox[{"Coefficient", "[", 
          RowBox[{"linelement", ",", 
           RowBox[{"dz", " ", "dx"}]}], "]"}], "/", "2"}], ",", 
        RowBox[{
         RowBox[{"Coefficient", "[", 
          RowBox[{"linelement", ",", 
           RowBox[{"dz", " ", "dy"}]}], "]"}], "/", "2"}], ",", 
        RowBox[{"Coefficient", "[", 
         RowBox[{"linelement", ",", 
          SuperscriptBox["dz", "2"]}], "]"}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"metric", "=", 
   RowBox[{"CTensor", "[", 
    RowBox[{"metricMatrix", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "chart"}], ",", 
       RowBox[{"-", "chart"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SetCMetric", "[", 
   RowBox[{"metric", ",", "chart", ",", 
    RowBox[{"SignatureOfMetric", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"3", ",", "1", ",", "0"}], "}"}]}]}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9137884864076223`*^9, 3.913788500399915*^9}, {
   3.9137886250324125`*^9, 3.9137886541032763`*^9}, {3.915161998047955*^9, 
   3.915162019941193*^9}, {3.916985219716387*^9, 3.916985257725456*^9}, {
   3.916985319394172*^9, 3.916985350840095*^9}, 3.916991316294529*^9, {
   3.916992150453645*^9, 3.9169921646677*^9}, {3.917416851392014*^9, 
   3.917416864894577*^9}, {3.917417689601429*^9, 3.917417732732632*^9}, {
   3.931235669657568*^9, 3.9312357083165436`*^9}, {3.931235738644102*^9, 
   3.931235805333507*^9}, 3.931252431213286*^9, {3.931253349941574*^9, 
   3.93125335975601*^9}, {3.931325882245613*^9, 3.931325912610607*^9}, {
   3.931403869512642*^9, 3.931403871271303*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"88e8e2ff-9dd5-cc44-8f4e-e61fd750acc3"],

Cell[TextData[{
 "First, let us determine its Petrov Type by using the corresponding ",
 StyleBox["xIdeal",
  FontSlant->"Italic"],
 " function:"
}], "Text",
 CellChangeTimes->{{3.931331759335284*^9, 3.931331824977211*^9}, {
   3.931407237074936*^9, 3.9314072724682407`*^9}, 3.9314073233290644`*^9, {
   3.931519726483244*^9, 3.9315197327402096`*^9}, {3.9774629038419247`*^9, 
   3.977462929071953*^9}, {3.9882492187654457`*^9, 
   3.9882492195966606`*^9}},ExpressionUUID->"483803a8-7105-f64e-8768-\
4c7bd55185ae"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"v", "=", 
   RowBox[{
    SqrtBox["2"], "\[ScriptA]", " ", 
    RowBox[{"CTensor", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Coefficient", "[", 
         RowBox[{"\[Omega]1", ",", "dt"}], "]"}], ",", 
        RowBox[{"Coefficient", "[", 
         RowBox[{"\[Omega]1", ",", "dx"}], "]"}], ",", 
        RowBox[{"Coefficient", "[", 
         RowBox[{"\[Omega]1", ",", "dy"}], "]"}], ",", 
        RowBox[{"Coefficient", "[", 
         RowBox[{"\[Omega]1", ",", "dz"}], "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"-", "chart"}], "}"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"PetrovType", "[", 
  RowBox[{"metric", ",", 
   RowBox[{"Verbose", "->", "False"}], ",", 
