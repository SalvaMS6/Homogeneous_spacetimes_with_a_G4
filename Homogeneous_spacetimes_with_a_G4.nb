   3.9774631311403656`*^9},ExpressionUUID->"2a261542-02f0-1e49-96b7-\
4e4592b996b7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"w1", "=", 
   RowBox[{"CTensor", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Coefficient", "[", 
        RowBox[{"\[Omega]1", ",", "dt"}], "]"}], ",", 
       RowBox[{"Coefficient", "[", 
        RowBox[{"\[Omega]1", ",", "dx"}], "]"}], ",", 
       RowBox[{"Coefficient", "[", 
        RowBox[{"\[Omega]1", ",", "dy"}], "]"}], ",", 
       RowBox[{"Coefficient", "[", 
        RowBox[{"\[Omega]1", ",", "dz"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"-", "chart"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"w2", "=", 
   RowBox[{"CTensor", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Coefficient", "[", 
        RowBox[{"\[Omega]2", ",", "dt"}], "]"}], ",", 
       RowBox[{"Coefficient", "[", 
        RowBox[{"\[Omega]2", ",", "dx"}], "]"}], ",", 
       RowBox[{"Coefficient", "[", 
        RowBox[{"\[Omega]2", ",", "dy"}], "]"}], ",", 
       RowBox[{"Coefficient", "[", 
        RowBox[{"\[Omega]2", ",", "dz"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"-", "chart"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"w3", "=", 
   RowBox[{"CTensor", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Coefficient", "[", 
        RowBox[{"\[Omega]3", ",", "dt"}], "]"}], ",", 
       RowBox[{"Coefficient", "[", 
        RowBox[{"\[Omega]3", ",", "dx"}], "]"}], ",", 
       RowBox[{"Coefficient", "[", 
        RowBox[{"\[Omega]3", ",", "dy"}], "]"}], ",", 
       RowBox[{"Coefficient", "[", 
        RowBox[{"\[Omega]3", ",", "dz"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"-", "chart"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"w4", "=", 
   RowBox[{"CTensor", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"-", "chart"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"e0", "=", 
   RowBox[{"\[ScriptA]", 
    SqrtBox["2"], "w1"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"e1", "=", 
   RowBox[{
    RowBox[{"\[ScriptA]", " ", "w4"}], "+", 
    RowBox[{"\[ScriptA]", 
     SqrtBox[
      RowBox[{"1", "-", 
       RowBox[{"2", 
        SuperscriptBox["s", "2"]}]}]], "w1"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"e2", "=", 
   RowBox[{"\[ScriptA]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SqrtBox[
         RowBox[{"1", "+", "s"}]], "w2"}], "+", 
       RowBox[{
        SqrtBox[
         RowBox[{"1", "-", "s"}]], "w3"}]}], ")"}], "/", 
     SqrtBox["2"]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"e3", "=", 
   RowBox[{"\[ScriptA]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SqrtBox[
         RowBox[{"1", "+", "s"}]], "w2"}], "-", 
       RowBox[{
        SqrtBox[
         RowBox[{"1", "-", "s"}]], "w3"}]}], ")"}], "/", 
     SqrtBox["2"]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.921033776069786*^9, 3.9210338943270435`*^9}, {
